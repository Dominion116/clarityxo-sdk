{
  "name": "clarityxo-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK and CLI for the ClarityXO on-chain Tic-Tac-Toe game on Stacks",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "clarityxo": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "stacks",
    "clarity",
    "blockchain",
    "tictactoe",
    "sdk",
    "web3"
  ],
  "author": "Dominion <limbotech116@gmail.com>",
  "author": "Dominion <limbotech116@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dominion116/clarityxo-sdk.git"
  },
  "homepage": "https://github.com/Dominion116/clarityxo-sdk#readme",
  "bugs": {
    "url": "https://github.com/Dominion116/clarityxo-sdk/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@stacks/blockchain-api-client": "^7.x",
    "@stacks/network": "^6.x",
    "@stacks/transactions": "^6.x",
    "chalk": "^5.x",
    "commander": "^12.x",
    "ora": "^8.x"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.x",
    "prettier": "^3.x",
    "tsup": "^8.x",
    "typescript": "^5.x",
    "vitest": "^1.x"
  }
}
